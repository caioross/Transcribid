<Application x:Class="AudioRecorder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- Brushes -->
        <SolidColorBrush x:Key="BgBrush"          Color="#0F0F10"/>
        <SolidColorBrush x:Key="PanelBrush"       Color="#15151A"/>
        <SolidColorBrush x:Key="PanelHoverBrush"  Color="#1B1B22"/>
        <SolidColorBrush x:Key="DividerBrush"     Color="#1F1F22"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#F5F5F7"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#A1A1A6"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#6B6B70"/>
        <SolidColorBrush x:Key="AccentRed"        Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentRedHover"   Color="#DC2626"/>
        <SolidColorBrush x:Key="AccentGreen"      Color="#34D399"/>
        <SolidColorBrush x:Key="AccentBlue"       Color="#60A5FA"/>
        <SolidColorBrush x:Key="MeterTrackBrush"  Color="#1C1C20"/>

        <!-- Big record button -->
        <Style x:Key="RecordButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="28,11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentRedHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stop button (used while recording) -->
        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource RecordButtonStyle}">
            <Setter Property="Background" Value="#27272A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3F3F46"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Subtle icon button (header / list rows) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F1F25"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Recording row action button -->
        <Style x:Key="ItemActionButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>

        <!-- Default scrollbar styling (thin, dark) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
        </Style>

    </Application.Resources>
</Application>
